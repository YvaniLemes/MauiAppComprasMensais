<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppComprasMensais.Views.ListaProduto"
             Title="Compras Mensais"
             BackgroundColor="White">

    <NavigationPage.TitleView>
        <Grid>
            <Label Text="  Compras Mensais"
                   FontSize="20"
                   FontFamily="Playfair"
                   FontAttributes="Bold"
                   TextColor="Black"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>
    </NavigationPage.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1" />
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked" />
        <ToolbarItem Text="Relatório" Clicked="ToolbarItem_Clicked_2" />
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Label">
                <Setter Property="VerticalTextAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <StackLayout>
        <SearchBar x:Name="txt_search" 
                   Margin="10, 0, 0, 0"
                   Placeholder="Busca de Produtos"
                   TextChanged="txt_search_TextChanged" />

        <Frame Padding="0" Margin="10" VerticalOptions="Fill">
            <ListView x:Name="lst_produtos" 
                      IsPullToRefreshEnabled="True"
                      Refreshing="lst_produtos_Refreshing"
                      ItemSelected="lst_produtos_ItemSelected">
                <ListView.Header>
                    <Grid BackgroundColor="LightGray">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Text=" ID" FontAttributes="Bold" TextColor="Black" />
                        <Label Grid.Column="1" Text="Descrição" FontAttributes="Bold" TextColor="Black" />
                        <Label Grid.Column="2" Text="Preço" FontAttributes="Bold" TextColor="Black" />
                        <Label Grid.Column="3" Text="Qnt" FontAttributes="Bold" TextColor="Black" />
                        <Label Grid.Column="4" Text="Total" FontAttributes="Bold" TextColor="Black" />
                        <Label Grid.Column="5" Text="Data de Compra" FontAttributes="Bold" TextColor="Black" />
                    </Grid>
                </ListView.Header>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <ViewCell.ContextActions>
                                <MenuItem Text="Remover" Clicked="MenuItem_Clicked" />
                            </ViewCell.ContextActions>
                            <Grid BackgroundColor="WhiteSmoke">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Text="{ Binding Id}" FontAttributes="Bold" TextColor="Black"/>
                                <Label Grid.Column="1" Text="{Binding Descricao}" FontAttributes="Bold" TextColor="Black"/>
                                <Label Grid.Column="2" Text="{Binding Preco, StringFormat='{}{0:c}'}" FontAttributes="Bold" TextColor="Black"/>
                                <Label Grid.Column="3" Text="{Binding Quantidade}" FontAttributes="Bold" TextColor="Black"/>
                                <Label Grid.Column="4" Text="{Binding Total, StringFormat='{}{0:c}'}" FontAttributes="Bold" TextColor="Black"/>
                                <Label Grid.Column="5" Text="{Binding DataCadastro, StringFormat='Comprado em: {0:dd/MM/yyyy}'}" FontAttributes="Bold" TextColor="Black"/>
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Frame>
    </StackLayout>
</ContentPage>